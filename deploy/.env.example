# Hetzner-miljö för brottsplatskartan
# Kopiera till ../.env på servern, chmod 600

APP_NAME=Brottsplatskartan
APP_ENV=production
APP_KEY=base64:<genereras-med-artisan-key-generate>
APP_DEBUG=false
APP_LOG_LEVEL=info
APP_URL=https://brottsplatskartan.se

# Databas (mariadb-containern)
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=brottsplatskartan
DB_USERNAME=brottsplatskartan
DB_PASSWORD=<generera-starkt-lösenord>
DB_ROOT_PASSWORD=<generera-starkt-lösenord>

# Redis (redis-containern)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<generera-starkt-lösenord>

# Cache-drivers — alla kör Redis
CACHE_DRIVER=redis
RESPONSE_CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_DRIVER=sync

# Tileserver — bind till rätt värde per miljö
TILESERVER_URL=https://kartbilder.brottsplatskartan.se/
# Under test: TILESERVER_URL=https://hetzner-kartbilder.brottsplatskartan.se/
# Kartbild-stil för enskilda händelser: 'circle' (röd tonad cirkel,
# default) eller 'bbox' (gammal viewport-rektangel, emergency-rollback).
# Lämnas tom/oset för att använda default 'circle'.
# TILESERVER_MAP_STYLE=circle

# Polisen
POLISEN_DOMAIN=https://polisen.se

# AI-tjänster (rotera innan första deploy!)
CLAUDE_API_KEY=

# Google (rotera innan första deploy!)
GEOCODE_GOOGLE_APIKEY=
GEOCODE_GOOGLE_LANGUAGE=sv
GOOGLE_API_KEY=
GOOGLE_SIGNING_SECRET=

# Relikt från gamla Wordpress-import? Kolla innan live.
WP_CONTENT_DIR=/var/www/html/public/assets
