# Global config
{
	email par.thernstrom@gmail.com
}

# Produktionsdomäner

# www → apex redirect
www.brottsplatskartan.se {
	redir https://brottsplatskartan.se{uri} permanent
}

brottsplatskartan.se {
	reverse_proxy app:8080
	encode gzip zstd
	# Security headers sätts av serversideup/php nginx (security.conf) —
	# dubblera inte här. X-Frame-Options sätts också där.
}

kartbilder.brottsplatskartan.se {
	reverse_proxy nginx-tiles:80
	encode gzip zstd
	# Aggressiv cache — tiles ändras sällan
	header Cache-Control "public, max-age=604800, immutable"
}

# Drop-in för co-hostade externa sajter — varje sajt levererar sin egen
# *.caddy från sitt repo via GitHub Actions till /opt/caddy-sites.d/ på
# servern. BPK-repot vet inget om vilka sajter som finns.
# Se deploy/co-hosted-static-sites.md.
import /etc/caddy/sites.d/*.caddy
