# Produktionsdomäner
brottsplatskartan.se, www.brottsplatskartan.se {
	redir https://brottsplatskartan.se{uri} permanent
}

brottsplatskartan.se {
	reverse_proxy app:8080
	encode gzip zstd
}

kartbilder.brottsplatskartan.se {
	reverse_proxy tileserver:8080
	encode gzip zstd

	# Aggressiv cache — tiles ändras sällan
	header Cache-Control "public, max-age=604800, immutable"
}

# Test-domäner (används under flytt, tas bort efter cutover)
hetzner.brottsplatskartan.se {
	reverse_proxy app:8080
	encode gzip zstd
}

hetzner-kartbilder.brottsplatskartan.se {
	reverse_proxy tileserver:8080
	encode gzip zstd
	header Cache-Control "public, max-age=604800, immutable"
}
