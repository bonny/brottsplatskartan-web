# Mall för LOKAL .env – kopiera till ../.env i projektroten.
#
# Lokalt kör vi samma stack som prod (samma images, samma versioner)
# men utan SSL och med Caddy avstängt. Ingen riktig trafik.

APP_NAME=Brottsplatskartan
APP_ENV=local
APP_KEY=base64:<genereras-automatiskt-första-gången-eller-kör-php-artisan-key-generate>
APP_DEBUG=true
APP_LOG_LEVEL=debug
APP_URL=http://localhost:8350

# Databas – ansluter till mariadb-containern
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=brottsplatskartan
DB_USERNAME=brottsplatskartan
DB_PASSWORD=local-dev-password
DB_ROOT_PASSWORD=local-dev-root-password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=local-dev-redis-password

# Cache
CACHE_DRIVER=redis
RESPONSE_CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_DRIVER=sync

# Tileserver – den lokala containern
TILESERVER_URL=http://localhost:8351/

# Polisen
POLISEN_DOMAIN=https://polisen.se

# AI-tjänster – fyll i om du vill testa AI-features lokalt
CLAUDE_API_KEY=

# Google – fyll i om du vill testa kartrelaterade features lokalt
GEOCODE_GOOGLE_APIKEY=
GEOCODE_GOOGLE_LANGUAGE=sv
GOOGLE_API_KEY=
GOOGLE_SIGNING_SECRET=

WP_CONTENT_DIR=/var/www/html/public/assets
