includes:
    - ./vendor/larastan/larastan/extension.neon

parameters:

    # Level 9 är högsta. 5 är rimligt för äldre Laravel-kodbas.
    level: 5

    paths:
        - app

    # Cache-katalog för snabbare efterföljande körningar.
    tmpDir: storage/framework/cache/phpstan

    # Minskar brus från Eloquent-accessors och PHPDoc som inte helt matchar
    # faktisk runtime-typ — typiskt i Laravel-projekt.
    treatPhpDocTypesAsCertain: false

    # Eloquent-modeller har dynamiska properties via magic __get.
    # Larastan tolkar de flesta korrekt men vissa relationer/kolumner
    # kräver @property-annoteringar. Accepterar detta i baseline.
    checkModelProperties: false

    # Avbryt inte körningen när ignoreErrors-mönster inte matchar
    # (t.ex. efter att en bugg fixats men mönstret glömts bort).
    reportUnmatchedIgnoredErrors: false
